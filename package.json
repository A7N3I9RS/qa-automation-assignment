{
  "name": "qa-automation-assignment",
  "version": "1.0.0",
  "description": "Playwright UI and API automation assignment for Moxymind.",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --project=ui",
    "test:ui:headed": "playwright test --project=ui --headed --workers=1",
    "test:defects": "playwright test --project=ui tests/ui/special-users.spec.ts",
    "test:defects:headed": "playwright test --project=ui tests/ui/special-users.spec.ts --headed --workers=1",
    "test:api": "playwright test --project=api",
    "report": "playwright show-report",
    "install:browsers": "playwright install chromium"
  },
  "keywords": [
    "playwright",
    "qa",
    "automation",
    "e2e",
    "api-testing"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.31",
    "typescript": "^5.8.3"
  }
}
