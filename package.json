{
  "name": "qa-automation-assignment",
  "version": "0.0.0",
  "description": "Playwright UI and API automation assignment for Moxymind.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:saucedemo:all-browsers": "playwright test --project=saucedemo-chromium --project=saucedemo-firefox --project=saucedemo-webkit",
    "test:saucedemo:chromium": "playwright test --project=saucedemo-chromium",
    "test:saucedemo:chromium:headed": "playwright test --project=saucedemo-chromium --headed --workers=1",
    "test:saucedemo:firefox": "playwright test --project=saucedemo-firefox",
    "test:saucedemo:webkit": "playwright test --project=saucedemo-webkit",
    "test:saucedemo:update-snapshots": "playwright test tests/saucedemo/checkout.spec.ts --project=saucedemo-chromium --project=saucedemo-firefox --project=saucedemo-webkit --grep \"(?=.*Checkout overview matches the baseline screenshot)(?=.*STANDARD_USER)\" --update-snapshots",
    "test:ui-mode": "playwright test --ui",
    "test:saucedemo:baseline": "playwright test --project=saucedemo-chromium tests/saucedemo/authentication.spec.ts tests/saucedemo/cart.spec.ts tests/saucedemo/checkout.spec.ts --grep \"STANDARD_USER|LOCKED_OUT_USER\"",
    "test:reqres": "playwright test --project=reqres",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "show-report": "playwright show-report",
    "install:browsers": "playwright install chromium firefox webkit"
  },
  "keywords": [
    "playwright",
    "qa",
    "automation",
    "e2e",
    "api-testing"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.13.1",
    "dotenv": "^17.4.2",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  }
}
