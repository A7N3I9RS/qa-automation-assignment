{
  "name": "qa-automation-assignment",
  "version": "0.0.0",
  "description": "Playwright UI and API automation assignment for Moxymind.",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:saucedemo": "playwright test --project=saucedemo",
    "test:saucedemo:headed": "playwright test --project=saucedemo --headed --workers=1",
    "test:ui": "playwright test --project=saucedemo",
    "test:ui-mode": "playwright test --ui",
    "test:ui:headed": "playwright test --project=saucedemo --headed --workers=1",
    "test:baseline": "playwright test --project=saucedemo tests/saucedemo/authentication.spec.ts tests/saucedemo/cart.spec.ts tests/saucedemo/checkout.spec.ts",
    "test:matrix": "playwright test --project=saucedemo tests/saucedemo/special-users.spec.ts",
    "test:matrix:headed": "playwright test --project=saucedemo tests/saucedemo/special-users.spec.ts --headed --workers=1",
    "test:defects": "playwright test --project=saucedemo tests/saucedemo/special-users.spec.ts",
    "test:defects:headed": "playwright test --project=saucedemo tests/saucedemo/special-users.spec.ts --headed --workers=1",
    "test:reqres": "playwright test --project=reqres",
    "test:api": "playwright test --project=reqres",
    "report": "playwright show-report",
    "install:browsers": "playwright install chromium firefox webkit"
  },
  "keywords": [
    "playwright",
    "qa",
    "automation",
    "e2e",
    "api-testing"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/node": "^22.15.31",
    "dotenv": "^17.4.2",
    "typescript": "^5.8.3"
  }
}
